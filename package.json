{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "packageManager": "pnpm@10.26.1",
  "scripts": {
    "preinstall": "node scripts/enforce-pnpm.cjs",
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck",
    "repo:mobile:typecheck": "pnpm --filter @workspace/mobile run typecheck",
    "repo:api:typecheck": "pnpm --filter @workspace/api-server run typecheck",
    "repo:db:push": "pnpm --filter @workspace/db run push",
    "repo:clean:artifacts": "find . \\( -name .cache -o -name .local -o -name .expo -o -name dist -o -name coverage \\) -type d -prune -exec rm -rf {} +",
    "repo:health": "pnpm run typecheck",
    "test": "vitest run"
  },
  "private": true,
  "devDependencies": {
    "@types/react": "~19.1.17",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "vitest": "^4.1.7"
  },
  "dependencies": {
    "@replit/connectors-sdk": "^0.4.1",
    "@replit/revenuecat-sdk": "^4.2.0",
    "@solana/web3.js": "^1.98.4",
    "expo": "~54.0.34",
    "expo-updates": "~29.0.18",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-native-web": "catalog:"
  },
  "optionalDependencies": {
    "@esbuild/win32-x64": "0.27.3",
    "@rollup/rollup-win32-x64-msvc": "4.59.0"
  },
  "main": "index.ts"
}