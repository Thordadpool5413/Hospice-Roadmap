{
  "cli": {
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "environment": "development"
    },
    "preview": {
      "distribution": "store",
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_BETA_OVERRIDE_PREMIUM": "true",
        "EXPO_DEBUG": "1"
      }
    },
    "production": {
      "distribution": "store",
      "environment": "production",
      "autoIncrement": true
    }
  }
}
