{
  "cli": {
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_BETA_OVERRIDE_PREMIUM": "true"
      }
    },
    "production": {
      "distribution": "store",
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_BETA_OVERRIDE_PREMIUM": "false"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {}
    }
  }
}
