# ───────────────────────────────────────────────────────────────
# EAS Build archive exclusions for artifacts/mobile (iOS/Android)
#
# EAS archives the entire monorepo root for the build context.
# These exclusions keep the upload small, fast, and secure by excluding
# everything the native iOS/Android build does NOT need.
# ───────────────────────────────────────────────────────────────

# CRITICAL for pnpm monorepo: exclude package-lock.json and yarn.lock
# so EAS detects and uses pnpm instead of npm (prevents build failures).
package-lock.json
yarn.lock

# Expo / build artifacts (not needed for native compilation)
.expo/
.expo-shared/
dist/
web-build/

# Native build folders (large and regenerated by EAS/Xcode/Gradle)
ios/
android/

# Secrets and sensitive files (already partially ignored at root, but reinforce here)
**/*.p8
**/*.p12
**/*.key
**/*.mobileprovision
.env
.env.*
.env.local
.env.*.local

# Other monorepo artifacts not needed for the mobile app build
artifacts/api-server
artifacts/app-preview-video
artifacts/mockup-sandbox

# Large media / generated assets (videos, PDFs, etc.)
attached_assets/generated_videos
attached_assets/*.mp4
attached_assets/*.mov
attached_assets/*.pdf
attached_assets/*.mov

# Development / tooling / cache (keep archive clean and fast)
node_modules
.cache
.local
.git
*.log
pnpm-debug.log*
npm-debug.log*
yarn-error.log*

# TypeScript / build info
*.tsbuildinfo
