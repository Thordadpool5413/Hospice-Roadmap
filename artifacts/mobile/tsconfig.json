{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "baseUrl": ".",
    "strict": true,
    "paths": {
      "@/*": [
        "./*"
      ],
      "@workspace/api-client-react": [
        "../../lib/api-client-react/src/index.ts"
      ],
      "@workspace/goc-merge": [
        "../../lib/goc-merge/src/index.ts"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ],
  "exclude": [
    "__tests__"
  ]
}
